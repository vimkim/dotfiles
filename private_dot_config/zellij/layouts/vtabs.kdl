// Opt-in layout with a vertical TAB sidebar (cfal/zellij-vertical-tabs).
//
//   Try it:   zellij --layout vtabs
//   Make default: set `default_layout "vtabs"` in config.kdl
//
// Note: this lists TABS vertically, not the panes inside a tab.
layout {
    pane split_direction="vertical" {
        // Fixed-width sidebar on the left listing tabs. Left-click / scroll to switch.
        pane size=25 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zellij-vertical-tabs.wasm" {
                // Only the ACTIVE tab is highlighted; inactive tabs use the
                // terminal's default colors (no bg). This sidesteps the plugin's
                // asymmetric `fill` (v0.1.0 honors it only on the selected row, so a
                // bg on inactive rows would stop at the end of the title rather than
                // spanning the rail). Active tab: Peach bg #fab387 with dark
                // fg #1e1e2e (catppuccin-mocha Base) + `fill` to paint the full row.
                // The Peach background alone marks the active tab, so we drop the
                // `{active}` (`*`) marker. No leading pad — rows start flush at col 0.
                format         "{index}:{name}"
                format_active  "#[bg=#fab387,fg=#1e1e2e,bold,fill]{index}:{name}"

                // The plugin truncates names TWICE: a per-token pass that cuts at
                // `max_name_length` and appends an "..." (default 20 when unset — so
                // *removing* this key does NOT disable it), then a line-level pass
                // that hard-cuts at the pane edge with NO ellipsis. We want only the
                // clean edge cut, so we set max_name_length far wider than the 25-col
                // sidebar can ever show: the "..." pass never fires, the edge cut does.
                max_name_length 100
            }
        }
        // Main working area (your panes live here). Frameless (inherits global
        // `pane_frames false`), so there is NO divider line — the sidebar's
        // colored background is the only thing separating it from the work area.
        pane
    }
    // Bottom status bar (full width). The vertical sidebar already lists tabs,
    // so this zjstatus instance DROPS {tabs} and shows session + MODE on the
    // left and a clock on the right. Mode is the whole point: with the
    // tmux-prefix keybinds in config.kdl this is the "am I in Normal / tmux /
    // scroll / …" indicator that the vertical-tabs plugin cannot render itself.
    pane size=1 borderless=true {
        // Managed by .chezmoiexternal.toml -> downloads to plugins/zjstatus.wasm
        // (mycompact.kdl still points at the hand-downloaded ~/temp/zjstatus copy).
        plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
            // -- Catppuccin Mocha (only the colors this bar references) --
            color_crust    "#11111b"
            color_surface0 "#1e1e2e"
            color_surface1 "#45475a"
            color_red      "#f38ba8"
            color_maroon   "#eba0ac"
            color_yellow   "#f9e2af"
            color_green    "#a6e3a1"
            color_teal     "#94e2d5"
            color_flamingo "#f2cdcd"
            color_pink     "#f5c2e7"
            color_mauve    "#cba6f7"
            color_sapphire "#74c7ec"

            // One chip per zellij input mode (powerline-faded into surface0).
            mode_normal        "#[bg=$green,fg=$crust,bold] N#[bg=$surface0,fg=$green]"
            mode_tmux          "#[bg=$mauve,fg=$crust,bold] T#[bg=$surface0,fg=$mauve]"
            mode_locked        "#[bg=$red,fg=$crust,bold] L#[bg=$surface0,fg=$red]"
            mode_pane          "#[bg=$teal,fg=$crust,bold] PANE#[bg=$surface0,fg=$teal]"
            mode_tab           "#[bg=$teal,fg=$crust,bold] TAB#[bg=$surface0,fg=$teal]"
            mode_scroll        "#[bg=$flamingo,fg=$crust,bold] SCROLL#[bg=$surface0,fg=$flamingo]"
            mode_enter_search  "#[bg=$flamingo,fg=$crust,bold] ENT-SEARCH#[bg=$surface0,fg=$flamingo]"
            mode_search        "#[bg=$flamingo,fg=$crust,bold] SEARCH#[bg=$surface0,fg=$flamingo]"
            mode_resize        "#[bg=$yellow,fg=$crust,bold] RESIZE#[bg=$surface0,fg=$yellow]"
            mode_rename_tab    "#[bg=$yellow,fg=$crust,bold] RENAME-TAB#[bg=$surface0,fg=$yellow]"
            mode_rename_pane   "#[bg=$yellow,fg=$crust,bold] RENAME-PANE#[bg=$surface0,fg=$yellow]"
            mode_move          "#[bg=$yellow,fg=$crust,bold] MOVE#[bg=$surface0,fg=$yellow]"
            mode_session       "#[bg=$pink,fg=$crust,bold] SESSION#[bg=$surface0,fg=$pink]"
            mode_prompt        "#[bg=$pink,fg=$crust,bold] PROMPT#[bg=$surface0,fg=$pink]"

            // left: session pill + mode chip ; right: clock. No {tabs} here.
            format_left  "#[bg=$surface0,fg=$sapphire]#[bg=$sapphire,fg=$crust,bold] {session} #[bg=$surface0] {mode}#[bg=$surface0]"
            format_right "#[bg=$surface0,fg=$maroon]#[bg=$maroon,fg=$crust]󰃭 #[bg=$surface1,fg=$maroon,bold] {datetime}#[bg=$surface0,fg=$surface1]"
            format_space "#[bg=$surface0]"
            format_hide_on_overlength "true"
            format_precedence "lrc"

            datetime        "{format}"
            datetime_format "%Y-%m-%d 󰅐 %H:%M"
            datetime_timezone "Asia/Seoul"
        }
    }
}
