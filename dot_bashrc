# .bashrc

path_prepend() {
    local dir
    for dir in "$@"; do
        [ -d "$dir" ] || continue
        case ":$PATH:" in
        *":$dir:"*) ;;
        *) PATH="$dir:$PATH" ;;
        esac
    done
    export PATH
}

