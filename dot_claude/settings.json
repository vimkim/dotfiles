{
  "permissions": {
    "allow": [
      "Read",
      "WebSearch",
      "WebFetch",
      "mcp__plugin_oh-my-claudecode_t__lsp_code_action_resolve",
      "mcp__plugin_oh-my-claudecode_t__lsp_code_actions",
      "mcp__plugin_oh-my-claudecode_t__lsp_diagnostics",
      "mcp__plugin_oh-my-claudecode_t__lsp_diagnostics_directory",
      "mcp__plugin_oh-my-claudecode_t__lsp_document_symbols",
      "mcp__plugin_oh-my-claudecode_t__lsp_find_references",
      "mcp__plugin_oh-my-claudecode_t__lsp_goto_definition",
      "mcp__plugin_oh-my-claudecode_t__lsp_hover",
      "mcp__plugin_oh-my-claudecode_t__lsp_prepare_rename",
      "mcp__plugin_oh-my-claudecode_t__lsp_rename",
      "mcp__plugin_oh-my-claudecode_t__lsp_servers",
      "mcp__plugin_oh-my-claudecode_t__lsp_workspace_symbols",
      "Grep",
      "Glob",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(just build:*)",
      "Bash(just test:*)",
      "Bash(just build-test:*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git blame*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(rg:*)"
    ],
    "additionalDirectories": [
      "/home/vimkim/gh"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'done' | curl -s -H 'Priority: min' -d @- ntfy.sh/vimkim-claude"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'jq -r .tool_name | curl -s -H \"Priority: min\" -d @- ntfy.sh/vimkim-claude'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node $HOME/.claude/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
